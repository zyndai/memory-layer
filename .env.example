# Copy to .env and fill in. .env is gitignored.

# --- Infra (match docker-compose.yml host ports) ---
DATABASE_URL=postgresql://zynd:zynd@localhost:5433/zynd
REDIS_URL=redis://localhost:6380

# --- Embeddings: OpenAI text-embedding-3-small (1536 dims) ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# --- Extraction: DeepSeek V3 (OpenAI-compatible endpoint) ---
# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
EXTRACTION_MODEL=deepseek-chat

# --- Dev auth: shared bearer mapped to DEV_USER_EMAIL (local testing only) ---
DEV_BEARER_TOKEN=dev-secret
DEV_USER_EMAIL=dev@zynd.local

# --- M2 auth: JWT + OAuth for the ChatGPT Action ---
# Use a random 32+ byte secret in production: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-me-in-production-0123456789
OAUTH_CLIENT_ID=zynd-chatgpt
OAUTH_CLIENT_SECRET=zynd-oauth-secret
# Public HTTPS URL of this API once deployed (used in the Action schema + OAuth URLs).
PUBLIC_BASE_URL=http://localhost:8000
# Public base URL of the MCP server (where MCP clients connect). May differ from
# PUBLIC_BASE_URL if the MCP server runs on a different host/port (e.g. port 8090).
MCP_PUBLIC_BASE_URL=http://localhost:8000

# --- OAuth provider credentials (for MCP tools: Twitter, LinkedIn, Google, Notion) ---
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# --- Exa / Tavily / Firecrawl (LinkedIn people search + profile enrichment) ---
# Exa: semantic neural search — primary LinkedIn profile finder
# Get a key at https://exa.ai
EXA_API_KEY=
# Tavily: keyword search — fallback if Exa is unavailable
# Get a key at https://tavily.com
TAVILY_API_KEY=
# Firecrawl: web scraping — enriches LinkedIn profiles with name/headline/about
# Get a key at https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Zynd Network ---
ZYND_REGISTRY_URL=https://zns01.zynd.ai
ZYND_DEPLOYER_URL=https://deployer.zynd.ai
ZYND_DEVELOPER_KEYPAIR_PATH=
PUBLIC_PAGE_BASE_URL=

# --- Supabase (for token store + persona data) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
